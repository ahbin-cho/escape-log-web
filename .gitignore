# 의존성 / 빌드 산출물
node_modules
.next
out
*.tsbuildinfo
next-env.d.ts

# OS / 로그
.DS_Store
*.log

# 환경변수 (보안)
# .env 는 NEXT_PUBLIC_* 공개 값만 담고 있어 의도적으로 커밋함(Vercel 빌드용).
#   → service_role 키, LLM API 키 등 "비밀"은 절대 .env 에 넣지 말 것.
# 아래 변형들은 비밀이 들어갈 수 있으므로 항상 무시.
.env*.local
.env.production
.env.development
*.pem

# 배포 도구 (vercel env pull 시 비밀이 여기로 내려올 수 있음)
.vercel

# 에디터
.idea

# 프로젝트 로컬 스크립트 / 슈파베이스 로컬 파일
scripts/*
supabase/*
next-env.d.ts
scripts/out
.omc/*
