# ─────────────────────────────────────────────────────────────
# Supabase (필수) — supabase.com 무료 프로젝트에서 복사
#   Project Settings → API 에서 확인
# 파일 이름을 .env.local 로 저장하세요.
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# 관리자 지정은 코드가 아니라 DB로 합니다:
#   Supabase SQL Editor 에서
#   insert into public.admins (email) values ('you@example.com');
# (supabase/schema.sql 하단 주석 참고)

# ─────────────────────────────────────────────────────────────
# (선택) AI 페르소나 진단을 "진짜 LLM"으로 켜려면 아래 중 하나
#   키가 없어도 앱은 규칙 기반으로 동작합니다.
# ─────────────────────────────────────────────────────────────
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# AI_MODEL=
